@{
    ViewData["Title"] = "Inicio";
}

<section class="hero">
    <div>
        <p class="eyebrow">Proyecto MVC</p>
        <h1>Catálogo de ropa para pequeños vendedores</h1>
        <p>
            Sistema web para administrar prendas, categorías, precios, tallas, colores,
            stock e imágenes de productos de forma sencilla.
        </p>
        <div class="actions">
            <a class="btn primary" asp-controller="Productos" asp-action="Index">Ver catálogo</a>
            <a class="btn" asp-controller="Productos" asp-action="Create">Agregar producto</a>
        </div>
    </div>
</section>

<section class="grid three">
    <article class="card">
        <h2>MVC</h2>
        <p>Separación entre modelos, vistas y controladores para mantener el proyecto ordenado.</p>
    </article>
    <article class="card">
        <h2>EF Core</h2>
        <p>Conexión con base de datos mediante Entity Framework Core y SQL Server.</p>
    </article>
    <article class="card">
        <h2>Catálogo</h2>
        <p>Funciones iniciales para crear, consultar, editar, filtrar y eliminar productos.</p>
    </article>
</section>
