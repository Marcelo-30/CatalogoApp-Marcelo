@model Producto
@{
    ViewData["Title"] = "Nuevo producto";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Producto</p>
        <h1>Nuevo producto</h1>
    </div>
    <a class="btn ghost" asp-action="Index">Volver</a>
</div>

<section class="card">
    <form asp-action="Create" method="post" class="form">
        <partial name="_ProductoForm" model="Model" />
        <div class="actions">
            <button class="btn primary" type="submit">Guardar</button>
            <a class="btn" asp-action="Index">Cancelar</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
