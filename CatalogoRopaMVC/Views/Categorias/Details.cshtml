@model Categoria
@{
    ViewData["Title"] = "Detalles de categoría";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Categoría</p>
        <h1>@Model.Nombre</h1>
    </div>
    <div class="actions">
        <a class="btn" asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
        <a class="btn ghost" asp-action="Index">Volver</a>
    </div>
</div>

<section class="card">
    <p>@Model.Descripcion</p>
    <h2>Productos en esta categoría</h2>
    @if (!Model.Productos.Any())
    {
        <p class="muted">No hay productos registrados en esta categoría.</p>
    }
    else
    {
        <ul class="clean-list">
            @foreach (var producto in Model.Productos)
            {
                <li>
                    <a asp-controller="Productos" asp-action="Details" asp-route-id="@producto.Id">@producto.Nombre</a>
                    <span class="muted">@producto.Precio.ToString("C")</span>
                </li>
            }
        </ul>
    }
</section>
