<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Catálogo de Ropa</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <nav class="nav-container">
            <a class="brand" asp-controller="Home" asp-action="Index">Catálogo de Ropa</a>
            <div class="nav-links">
                <a asp-controller="Home" asp-action="Index">Inicio</a>
                <a asp-controller="Productos" asp-action="Index">Productos</a>
                <a asp-controller="Categorias" asp-action="Index">Categorías</a>
            </div>
        </nav>
    </header>

    <main class="container">
        @if (TempData["Mensaje"] != null)
        {
            <div class="alert success">@TempData["Mensaje"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert danger">@TempData["Error"]</div>
        }

        @RenderBody()
    </main>

    <footer class="footer">
        <p>&copy; @DateTime.Now.Year - Catálogo de Ropa MVC</p>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
