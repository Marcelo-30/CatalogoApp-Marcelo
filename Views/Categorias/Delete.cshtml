@model Categoria
@{
    ViewData["Title"] = "Eliminar categoría";
}

<section class="card danger-zone">
    <h1>Eliminar categoría</h1>
    <p>¿Seguro que deseas eliminar <strong>@Model.Nombre</strong>?</p>

    @if (Model.Productos.Any())
    {
        <div class="alert danger">
            No puedes eliminar esta categoría porque tiene @Model.Productos.Count producto(s) registrado(s).
        </div>
        <a class="btn" asp-action="Index">Volver</a>
    }
    else
    {
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="actions">
                <button class="btn danger" type="submit">Sí, eliminar</button>
                <a class="btn" asp-action="Index">Cancelar</a>
            </div>
        </form>
    }
</section>
