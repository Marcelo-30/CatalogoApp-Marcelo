@{
    ViewData["Title"] = "Inicio";
}

<section class="home-hero">
    <div class="home-hero-content">
        <p class="eyebrow">Nueva temporada</p>
        <h1>Catalogo de ropa con estilo propio</h1>
        <p>
            Explora prendas disponibles, colores, tallas y precios en una experiencia pensada
            para comprar rapido y mirar con calma.
        </p>
        <div class="actions">
            <a class="btn primary" asp-controller="Productos" asp-action="Index">Ver catalogo</a>
            @if (User.IsInRole("Vendedor"))
            {
                <a class="btn light" asp-controller="Productos" asp-action="Create">Administrar productos</a>
            }
        </div>
    </div>
</section>

<section class="home-showcase">
    <div>
        <p class="eyebrow">Seleccion visual</p>
        <h2>Prendas listas para destacar</h2>
    </div>
    <a class="text-link" asp-controller="Productos" asp-action="Index">Explorar disponibles</a>
</section>
