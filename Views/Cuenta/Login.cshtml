@model LoginViewModel
@{
    ViewData["Title"] = "Acceso de vendedor";
    var puedeRegistrarVendedor = ViewBag.PuedeRegistrarVendedor as bool? ?? false;
}

<div class="page-header">
    <div>
        <p class="eyebrow">Cuenta</p>
        <h1>Acceso de vendedor</h1>
    </div>
    <a class="btn ghost" asp-controller="Productos" asp-action="Index">Ver catalogo</a>
</div>

<section class="card auth-card">
    <p class="muted">
        El catalogo es publico para clientes. Solo el vendedor dueno puede iniciar sesion para crear,
        editar o eliminar productos.
    </p>

    <form asp-action="Login" method="post" class="form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Email"></label>
            <input asp-for="Email" autocomplete="username" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password"></label>
            <input asp-for="Password" autocomplete="current-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="actions">
            <button class="btn primary" type="submit">Entrar como vendedor</button>
            @if (puedeRegistrarVendedor)
            {
                <a class="btn" asp-action="Registro">Registrar vendedor dueno</a>
            }
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
