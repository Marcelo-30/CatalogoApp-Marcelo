@model IEnumerable<Producto>
@{
    ViewData["Title"] = "Catalogo";
}

<div class="page-header catalog-header">
    <div>
        <p class="eyebrow">Catalogo</p>
        <h1>Coleccion disponible</h1>
        <p class="page-subtitle">Prendas con imagen, precio, talla, color y disponibilidad actual.</p>
    </div>
    @if (User.IsInRole("Vendedor"))
    {
        <a class="btn primary" asp-action="Create">Nuevo producto</a>
    }
</div>

<form asp-action="Index" method="get" class="filters">
    <div class="form-group">
        <label for="buscar">Buscar</label>
        <input id="buscar" name="buscar" value="@ViewData["Buscar"]" placeholder="Nombre, color o talla" />
    </div>

    <div class="form-group">
        <label for="categoriaId">Categoria</label>
        <select id="categoriaId" name="categoriaId" asp-items="ViewBag.Categorias">
            <option value="">Todas</option>
        </select>
    </div>

    <label class="check filter-check">
        <input type="checkbox" name="soloDisponibles" value="true" @(ViewData["SoloDisponibles"] is true ? "checked" : "") />
        Solo disponibles
    </label>

    <button class="btn dark" type="submit">Filtrar</button>
    <a class="btn ghost" asp-action="Index">Limpiar</a>
</form>

@if (!Model.Any())
{
    <section class="empty-state">
        <h2>No hay prendas para mostrar</h2>
        <p>Prueba con otros filtros o agrega un nuevo producto si eres vendedor.</p>
    </section>
}
else
{
    <section class="product-grid">
        @foreach (var producto in Model)
        {
            var disponible = producto.Disponible && producto.Stock > 0;
            <article class="product-card">
                <a class="product-image" asp-action="Details" asp-route-id="@producto.Id" aria-label="Ver @producto.Nombre">
                    @if (!string.IsNullOrWhiteSpace(producto.ImagenPrincipalUrl))
                    {
                        <img src="@producto.ImagenPrincipalUrl" alt="Imagen de @producto.Nombre" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';" />
                        <span class="image-fallback">Sin imagen</span>
                    }
                    else
                    {
                        <span class="image-fallback visible">Sin imagen</span>
                    }
                    <span class="badge @(disponible ? "available" : "soldout")">
                        @(disponible ? "Disponible" : "Agotado")
                    </span>
                </a>

                <div class="product-body">
                    <p class="product-category">@producto.Categoria?.Nombre</p>
                    <h2>@producto.Nombre</h2>
                    <p class="product-description">@producto.Descripcion</p>
                    <p class="price">@producto.Precio.ToString("C")</p>

                    <div class="product-meta">
                        <span>Talla @producto.Talla?.Nombre</span>
                        <span>@producto.Color?.Nombre</span>
                        <span>@producto.Stock en stock</span>
                    </div>

                    <div class="actions small-actions">
                        <a class="btn compact" asp-action="Details" asp-route-id="@producto.Id">Detalles</a>
                        @if (User.IsInRole("Vendedor"))
                        {
                            <a class="text-link" asp-action="Edit" asp-route-id="@producto.Id">Editar</a>
                            <a class="text-link danger-link" asp-action="Delete" asp-route-id="@producto.Id">Eliminar</a>
                        }
                    </div>
                </div>
            </article>
        }
    </section>
}
