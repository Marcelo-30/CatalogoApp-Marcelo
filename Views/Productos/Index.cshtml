@model IEnumerable<Producto>
@{
    ViewData["Title"] = "Productos";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Catálogo</p>
        <h1>Productos</h1>
    </div>
    <a class="btn primary" asp-action="Create">Nuevo producto</a>
</div>

<form asp-action="Index" method="get" class="filters card">
    <div class="form-group">
        <label for="buscar">Buscar</label>
        <input id="buscar" name="buscar" value="@ViewData["Buscar"]" placeholder="Nombre, color, talla..." />
    </div>

    <div class="form-group">
        <label for="categoriaId">Categoría</label>
        <select id="categoriaId" name="categoriaId" asp-items="ViewBag.Categorias">
            <option value="">Todas</option>
        </select>
    </div>

    <label class="check">
        <input type="checkbox" name="soloDisponibles" value="true" @(ViewData["SoloDisponibles"] is true ? "checked" : "") />
        Solo disponibles
    </label>

    <button class="btn" type="submit">Filtrar</button>
    <a class="btn ghost" asp-action="Index">Limpiar</a>
</form>

@if (!Model.Any())
{
    <section class="card empty">
        <h2>No hay productos</h2>
        <p>Agrega productos o cambia los filtros de búsqueda.</p>
    </section>
}
else
{
    <section class="product-grid">
        @foreach (var producto in Model)
        {
            <article class="product-card">
                <div class="product-image">
                    @if (!string.IsNullOrWhiteSpace(producto.ImagenPrincipalUrl))
                    {
                        <img src="@producto.ImagenPrincipalUrl" alt="Imagen de @producto.Nombre" />
                    }
                    else
                    {
                        <span>Sin imagen</span>
                    }
                </div>
                <div class="product-body">
                    <div class="product-title-row">
                        <h2>@producto.Nombre</h2>
                        <span class="badge @(producto.Disponible && producto.Stock > 0 ? "available" : "soldout")">
                            @(producto.Disponible && producto.Stock > 0 ? "Disponible" : "Agotado")
                        </span>
                    </div>
                    <p class="muted">@producto.Categoria?.Nombre</p>
                    <p>@producto.Descripcion</p>
                    <p class="price">@producto.Precio.ToString("C")</p>
                    <p class="small">Talla: @producto.Talla?.Nombre | Color: @producto.Color?.Nombre | Stock: @producto.Stock</p>
                    <div class="actions small-actions">
                        <a asp-action="Details" asp-route-id="@producto.Id">Detalles</a>
                        <a asp-action="Edit" asp-route-id="@producto.Id">Editar</a>
                        <a asp-action="Delete" asp-route-id="@producto.Id">Eliminar</a>
                    </div>
                </div>
            </article>
        }
    </section>
}
