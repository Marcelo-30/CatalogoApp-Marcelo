@model Producto
@{
    ViewData["Title"] = "Detalles";
    var disponible = Model.Disponible && Model.Stock > 0;
}

<div class="page-header">
    <div>
        <p class="eyebrow">Producto</p>
        <h1>@Model.Nombre</h1>
    </div>
    <div class="actions">
        @if (User.IsInRole("Vendedor"))
        {
            <a class="btn primary" asp-action="Edit" asp-route-id="@Model.Id">Editar</a>
        }
        <a class="btn ghost" asp-action="Index">Volver</a>
    </div>
</div>

<section class="product-detail">
    <div class="product-image large">
        @if (!string.IsNullOrWhiteSpace(Model.ImagenPrincipalUrl))
        {
            <img src="@Model.ImagenPrincipalUrl" alt="Imagen de @Model.Nombre" onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';" />
            <span class="image-fallback">Sin imagen</span>
        }
        else
        {
            <span class="image-fallback visible">Sin imagen</span>
        }
    </div>

    <div class="detail-panel">
        <span class="badge @(disponible ? "available" : "soldout")">
            @(disponible ? "Disponible" : "No disponible")
        </span>
        <p class="price detail-price">@Model.Precio.ToString("C")</p>
        <p class="detail-description">@Model.Descripcion</p>

        <dl class="details-list">
            <dt>Categoria</dt>
            <dd>@Model.Categoria?.Nombre</dd>
            <dt>Talla</dt>
            <dd>@Model.Talla?.Nombre</dd>
            <dt>Color</dt>
            <dd>@Model.Color?.Nombre</dd>
            <dt>Stock</dt>
            <dd>@Model.Stock</dd>
            <dt>Imagenes</dt>
            <dd>@Model.Imagenes.Count</dd>
            <dt>Registro</dt>
            <dd>@Model.FechaRegistro.ToShortDateString()</dd>
        </dl>
    </div>
</section>
