@model Producto

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<div class="form-grid">
    <div class="form-group">
        <label asp-for="Nombre"></label>
        <input asp-for="Nombre" placeholder="Ej. Chamarra denim oversize" />
        <span asp-validation-for="Nombre" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="CategoriaId"></label>
        <select asp-for="CategoriaId" asp-items="ViewBag.Categorias">
            <option value="">Selecciona una categoría</option>
        </select>
        <span asp-validation-for="CategoriaId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="TallaId"></label>
        <select asp-for="TallaId" asp-items="ViewBag.Tallas">
            <option value="">Selecciona una talla</option>
        </select>
        <span asp-validation-for="TallaId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ColorId"></label>
        <select asp-for="ColorId" asp-items="ViewBag.Colores">
            <option value="">Selecciona un color</option>
        </select>
        <span asp-validation-for="ColorId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Precio"></label>
        <input asp-for="Precio" type="number" step="0.01" min="0" />
        <span asp-validation-for="Precio" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Stock"></label>
        <input asp-for="Stock" type="number" min="0" />
        <span asp-validation-for="Stock" class="text-danger"></span>
    </div>
</div>

<div class="form-group">
    <label asp-for="ImagenUrl"></label>
    <input asp-for="ImagenUrl" placeholder="https://images.example.com/prenda.jpg" />
    <span asp-validation-for="ImagenUrl" class="text-danger"></span>
</div>

<div class="form-group">
    <label asp-for="Descripcion"></label>
    <textarea asp-for="Descripcion" rows="4" placeholder="Describe textura, corte, ocasion de uso o detalle principal."></textarea>
    <span asp-validation-for="Descripcion" class="text-danger"></span>
</div>

<label class="check">
    <input asp-for="Disponible" />
    Disponible para venta
</label>
