@model Producto
@{
    ViewData["Title"] = "Nuevo producto";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Administracion</p>
        <h1>Nuevo producto</h1>
        <p class="page-subtitle">Agrega una prenda con imagen, precio, stock y variantes claras.</p>
    </div>
    <a class="btn ghost" asp-action="Index">Volver</a>
</div>

<section class="form-shell">
    <form asp-action="Create" method="post" class="form">
        <partial name="_ProductoForm" model="Model" />
        <div class="actions form-actions">
            <button class="btn primary" type="submit">Guardar producto</button>
            <a class="btn ghost" asp-action="Index">Cancelar</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
